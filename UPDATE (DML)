select * from zoho;
SET SQL_SAFE_UPDATES = 0;
update zoho set city = "mysore";
update zoho set city = if (dept = "cse","delhi","banglore");
insert into zoho values(5,"anbu","cse",1,"chennai");
insert into zoho values(6,"bala","IT",1,"chennai");
update zoho set dept = "eee" where sno in (1,4,5);
