alter table zoho add column bonus int(10);
update zoho set bonus = case
when exp>1 then 1000
when exp>2 then 2000
else 0
end;
update zoho set dept = "mech" where city = "banglore" and exp = 2;
update zoho set dept = "aero" where city = "banglore" or exp = 3;
update zoho set city = substring(city,1,3);
alter table zoho add column Fname varchar(20);
update zoho set Fname = concat(name,"sri");
update zoho set dept = replace (dept,"eee","electri");
alter table zoho add column dob date;
update zoho set dob=curdate();
alter table zoho add column jd date;
update zoho set jd = date_add(dob,interval 5 day);
update zoho set city = null where dept = "cse";
update zoho set city = ifnull(city,"del");

