select * from zoo order by mark;
select * from zoo order by mark desc;
select * from zoo order by mark limit 2;
select * from zoo order by mark, dept;
select name as studname from zoo;
select count(*) from zoo;
select count(*) from zoo where dept = 'CSE';
select avg(mark) from zoo where dept = 'CSE';
select dept, count(*) from zoo group by dept;
select name,case when mark >= 90 then 'Distinction'when mark >= 40 then 'Pass'else 'Fail'end as status from zoo;
select name, age,
case 
    when age <= 20 then 'student'
    else 'citizen'
end as nature
from zoo;
